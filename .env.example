# =============================================================================
# Environment variables for the Cortex Agent TruLens evaluation
# Copy this file to .env, fill in your values, then source it before running:
#   source .env && python evaluate.py
# =============================================================================

# -----------------------------------------------------------------------------
# Snowflake Cortex Agent — REST API (PAT-based auth)
# Used by: agent_client.py
# -----------------------------------------------------------------------------

# Personal Access Token (PAT) — generate in Snowsight:
#   Profile → Settings → Authentication → Programmatic access tokens
CORTEX_AGENT_DEMO_PAT=<your-pat-token>

# Snowflake account URL (without https://)
#   e.g. abc12345.snowflakecomputing.com
CORTEX_AGENT_DEMO_HOST=<account>.snowflakecomputing.com

# Agent resource coordinates (defaults shown)
CORTEX_AGENT_DEMO_DATABASE=SNOWFLAKE_INTELLIGENCE
CORTEX_AGENT_DEMO_SCHEMA=AGENTS
CORTEX_AGENT_DEMO_AGENT=SALES_INTELLIGENCE_AGENT

# -----------------------------------------------------------------------------
# Snowflake Snowpark session — for TruLens Cortex feedback provider
# Used by: evaluate.py
# -----------------------------------------------------------------------------

# Account identifier — same as your account URL prefix
#   e.g. abc12345 or orgname-accountname
SNOWFLAKE_ACCOUNT=<account-identifier>

SNOWFLAKE_USER=<your-username>

# --- Option A: SSO (recommended) ---
# Opens a browser window to complete SSO login. No password needed.
SNOWFLAKE_AUTHENTICATOR=externalbrowser

# --- Option B: password auth (comment out Option A above) ---
# SNOWFLAKE_AUTHENTICATOR=snowflake
# SNOWFLAKE_PASSWORD=<your-password>

# --- Option C: private key / key-pair auth (comment out Option A above) ---
# SNOWFLAKE_AUTHENTICATOR=snowflake
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8

# Explicit hostname for the Snowpark session (fixes SSL hostname-mismatch errors).
# If not set, CORTEX_AGENT_DEMO_HOST is used as a fallback.
# Usually the same as CORTEX_AGENT_DEMO_HOST.
# SNOWFLAKE_HOST=<account>.snowflakecomputing.com

# Role, warehouse, and database for the feedback session
SNOWFLAKE_ROLE=sales_intelligence_role
SNOWFLAKE_WAREHOUSE=SALES_INTELLIGENCE_WH
SNOWFLAKE_DATABASE=SALES_INTELLIGENCE
SNOWFLAKE_SCHEMA=DATA
